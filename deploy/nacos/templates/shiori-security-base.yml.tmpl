security:
  jwt:
    issuer: shiori
    access-ttl-seconds: 900
    refresh-ttl-seconds: 604800
  gateway-sign:
    max-skew-seconds: 300
    replay-protection-enabled: true
    replay-cache-max-entries: 200000
    anonymous-get-paths:
      - /api/v2/product/**
      - /api/user/profiles/**
      - /api/user/media/avatar/**
      - /api/v2/product/users/**
      - /api/v2/order/reviews/users/**
      - /api/v2/order/reviews/products/**
      - /api/v2/social/users/*/posts
