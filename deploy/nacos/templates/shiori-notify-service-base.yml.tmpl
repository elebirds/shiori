notify:
  http:
    addr: ${NOTIFY_HTTP_ADDR}
  kafka:
    enabled: ${NOTIFY_KAFKA_ENABLED:true}
    brokers: ${KAFKA_BOOTSTRAP_SERVERS:127.0.0.1:9092}
    topics: ${NOTIFY_KAFKA_TOPICS:shiori.cdc.order.outbox.raw,shiori.cdc.user.outbox.raw}
    group-id: ${NOTIFY_KAFKA_GROUP_ID:shiori-notify-cdc}
  redis:
    addr: ${NOTIFY_REDIS_ADDR}
  log:
    level: info
  ws:
    path: ${NOTIFY_WS_PATH}
    write-timeout: 5s
    ping-interval: 30s
  metrics:
    enabled: true
  store:
    driver: mysql
    max-per-user: 1000
  replay:
    default-limit: 50
    max-limit: 200
    ws-limit: 100
  auth:
    enabled: true
  mysql:
    max-open-conns: 20
    max-idle-conns: 10
    conn-max-lifetime: 30m
  chat:
    enabled: ${NOTIFY_CHAT_ENABLED}
    default-limit: ${NOTIFY_CHAT_DEFAULT_LIMIT}
    max-limit: ${NOTIFY_CHAT_MAX_LIMIT}
    ticket-issuer: ${CHAT_TICKET_ISSUER}
    pubsub-enabled: ${NOTIFY_CHAT_PUBSUB_ENABLED}
    pubsub-channel: ${NOTIFY_CHAT_PUBSUB_CHANNEL}
