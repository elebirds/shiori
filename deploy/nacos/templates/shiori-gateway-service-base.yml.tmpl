spring:
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT}

security:
  auth:
    whitelist:
      - /actuator/health/**
      - /v3/api-docs/**
      - /swagger-ui/**
      - /swagger-ui.html
      - /api/user/auth/register
      - /api/user/auth/login
      - /api/user/auth/refresh
      - /api/user/auth/logout
    anonymous-get-paths:
      - /api/v2/product/**
      - /api/user/profiles/**
      - /api/user/media/avatar/**
      - /api/v2/product/users/**
      - /api/v2/order/reviews/users/**
      - /api/v2/social/users/*/posts
  rate-limit:
    enabled: ${GATEWAY_RATE_LIMIT_ENABLED:false}
    login-per-second: ${GATEWAY_RATE_LIMIT_LOGIN_PER_SECOND:20}
    order-create-per-second: ${GATEWAY_RATE_LIMIT_ORDER_CREATE_PER_SECOND:30}
    order-pay-per-second: ${GATEWAY_RATE_LIMIT_ORDER_PAY_PER_SECOND:50}
  authz:
    user-service-base-url: http://shiori-user-service
    cache:
      redis:
        enabled: ${SECURITY_AUTHZ_CACHE_REDIS_ENABLED:true}
        key-prefix: ${SECURITY_AUTHZ_CACHE_REDIS_KEY_PREFIX:authz:snapshot:}
        ttl-seconds: ${SECURITY_AUTHZ_CACHE_REDIS_TTL_SECONDS:30}
        stale-ttl-seconds: ${SECURITY_AUTHZ_CACHE_REDIS_STALE_TTL_SECONDS:300}
    event:
      enabled: ${SECURITY_AUTHZ_EVENT_ENABLED:true}
      redis-channel: ${SECURITY_AUTHZ_EVENT_REDIS_CHANNEL:shiori.authz.user.changed}

management:
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  endpoint:
    health:
      show-details: never
