spring:
  datasource:
    url: ${SOCIAL_DB_URL}
  rabbitmq:
    host: ${SOCIAL_RMQ_HOST}
    port: ${SOCIAL_RMQ_PORT}
    virtual-host: /
    listener:
      simple:
        default-requeue-rejected: false
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT}
  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration

mybatis:
  mapper-locations: classpath*:mapper/**/*.xml
  configuration:
    map-underscore-to-camel-case: true

storage:
  oss:
    enabled: true
    endpoint: ${PRODUCT_OSS_ENDPOINT}
    region: us-east-1
    bucket: ${MINIO_PRODUCT_BUCKET}
    path-style-access: true
    presign-put-expire-seconds: 300
    presign-get-expire-seconds: 300

social:
  user-client:
    service-base-url: ${SOCIAL_USER_SERVICE_BASE_URL}
  mq:
    enabled: ${SOCIAL_MQ_ENABLED:true}
    product-event-exchange: ${PRODUCT_EVENT_EXCHANGE:shiori.product.event}
    product-published-routing-key: ${PRODUCT_PUBLISHED_ROUTING_KEY:product.published}
    product-published-queue: ${SOCIAL_PRODUCT_PUBLISHED_QUEUE:q.social.product.published}
    product-published-dlx-exchange: ${SOCIAL_PRODUCT_PUBLISHED_DLX_EXCHANGE:shiori.social.product.dlx}
    product-published-dlq-routing-key: ${SOCIAL_PRODUCT_PUBLISHED_DLQ_ROUTING_KEY:product.published.dlq}
    product-published-dlq-queue: ${SOCIAL_PRODUCT_PUBLISHED_DLQ_QUEUE:q.social.product.published.dlq}

management:
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  endpoint:
    health:
      show-details: never
