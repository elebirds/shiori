spring:
  datasource:
    url: ${ORDER_DB_URL}
    hikari:
      maximum-pool-size: ${ORDER_DB_MAX_POOL_SIZE:20}
      minimum-idle: ${ORDER_DB_MIN_IDLE:10}
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT}
  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration
  rabbitmq:
    host: ${ORDER_RMQ_HOST}
    port: ${ORDER_RMQ_PORT}
    virtual-host: /

mybatis:
  mapper-locations: classpath*:mapper/**/*.xml
  configuration:
    map-underscore-to-camel-case: true

order:
  timeout-minutes: 15
  review:
    window-days: ${ORDER_REVIEW_WINDOW_DAYS:15}
    edit-hours: ${ORDER_REVIEW_EDIT_HOURS:24}
    comment-max-length: ${ORDER_REVIEW_COMMENT_MAX_LENGTH:280}
  product-client:
    service-base-url: http://shiori-product-service
  payment-client:
    service-base-url: http://shiori-payment-service
  notify-client:
    service-base-url: http://shiori-notify-service
  outbox:
    enabled: true
    relay-fixed-delay-ms: 3000
    relay-batch-size: 100
    max-backoff-seconds: 300
  command:
    enabled: true
    recovery-fixed-delay-ms: ${ORDER_COMMAND_RECOVERY_FIXED_DELAY_MS:3000}
    recovery-batch-size: ${ORDER_COMMAND_RECOVERY_BATCH_SIZE:100}
    stale-prepared-seconds: ${ORDER_COMMAND_STALE_PREPARED_SECONDS:30}
    max-backoff-seconds: ${ORDER_COMMAND_MAX_BACKOFF_SECONDS:300}
  mq:
    enabled: true
    event-exchange: shiori.order.event
    order-created-routing-key: order.created
    order-paid-routing-key: order.paid
    order-canceled-routing-key: order.canceled
    order-delivered-routing-key: order.delivered
    order-finished-routing-key: order.finished
    delay-exchange: shiori.order.delay
    delay-routing-key: order.timeout
    timeout-dlx-exchange: shiori.order.timeout.dlx
    timeout-delay-queue: q.order.timeout.delay
    timeout-consume-queue: q.order.timeout.consume
    timeout-ttl-ms: 900000

management:
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  endpoint:
    health:
      show-details: never
