spring:
  datasource:
    url: ${ORDER_DB_URL}
    hikari:
      maximum-pool-size: ${ORDER_DB_MAX_POOL_SIZE:20}
      minimum-idle: ${ORDER_DB_MIN_IDLE:10}
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT}
  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration
  kafka:
    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS:127.0.0.1:9092}

mybatis:
  mapper-locations: classpath*:mapper/**/*.xml
  configuration:
    map-underscore-to-camel-case: true

order:
  timeout-minutes: 15
  timeout-scheduler:
    enabled: ${ORDER_TIMEOUT_SCHEDULER_ENABLED:true}
    fixed-delay-ms: ${ORDER_TIMEOUT_SCHEDULER_FIXED_DELAY_MS:3000}
    batch-size: ${ORDER_TIMEOUT_SCHEDULER_BATCH_SIZE:100}
  kafka:
    enabled: ${ORDER_KAFKA_ENABLED:false}
    wallet-balance-outbox-topic: ${ORDER_WALLET_BALANCE_OUTBOX_TOPIC:shiori.cdc.payment.outbox.raw}
    wallet-balance-outbox-group-id: ${ORDER_WALLET_BALANCE_OUTBOX_GROUP_ID:shiori-order-wallet-cdc}
  review:
    window-days: ${ORDER_REVIEW_WINDOW_DAYS:15}
    edit-hours: ${ORDER_REVIEW_EDIT_HOURS:24}
    comment-max-length: ${ORDER_REVIEW_COMMENT_MAX_LENGTH:280}
  product-client:
    service-base-url: ${ORDER_PRODUCT_SERVICE_BASE_URL:http://shiori-product-service}
  user-client:
    service-base-url: ${ORDER_USER_SERVICE_BASE_URL:http://shiori-user-service}
  payment-client:
    service-base-url: ${ORDER_PAYMENT_SERVICE_BASE_URL:http://shiori-payment-service}
  notify-client:
    service-base-url: ${ORDER_NOTIFY_SERVICE_BASE_URL:http://shiori-notify-service}
  command:
    enabled: true
    recovery-fixed-delay-ms: ${ORDER_COMMAND_RECOVERY_FIXED_DELAY_MS:3000}
    recovery-batch-size: ${ORDER_COMMAND_RECOVERY_BATCH_SIZE:100}
    stale-prepared-seconds: ${ORDER_COMMAND_STALE_PREPARED_SECONDS:30}
    max-backoff-seconds: ${ORDER_COMMAND_MAX_BACKOFF_SECONDS:300}
  mq:
    event-exchange: shiori.order.event
    order-created-routing-key: order.created
    order-paid-routing-key: order.paid
    order-canceled-routing-key: order.canceled
    order-delivered-routing-key: order.delivered
    order-finished-routing-key: order.finished

management:
  defaults:
    metrics:
      export:
        enabled: false
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  endpoint:
    health:
      show-details: never
  tracing:
    enabled: ${TRACING_ENABLED:true}
    sampling:
      probability: ${TRACING_SAMPLING_PROBABILITY:1.0}
    propagation:
      consume: [w3c]
      produce: [w3c]
  opentelemetry:
    resource-attributes:
      service.namespace: shiori
      deployment.environment: ${SHIORI_ENV:dev}
    tracing:
      export:
        otlp:
          endpoint: ${OTEL_EXPORTER_OTLP_ENDPOINT:http://jaeger:4318/v1/traces}
  otlp:
    metrics:
      export:
        enabled: false
  logging:
    export:
      otlp:
        enabled: false

logging:
  include-application-name: false
  pattern:
    correlation: "[${spring.application.name:},%X{traceId:-},%X{spanId:-}] "
