spring:
  datasource:
    url: ${USER_DB_URL}
  rabbitmq:
    host: ${USER_RMQ_HOST}
    port: ${USER_RMQ_PORT}
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT}
  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration

mybatis:
  mapper-locations: classpath*:mapper/**/*.xml
  configuration:
    map-underscore-to-camel-case: true

management:
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  endpoint:
    health:
      show-details: never

user:
  authz:
    snapshot-ttl-seconds: ${USER_AUTHZ_SNAPSHOT_TTL_SECONDS:30}
    event:
      enabled: ${USER_AUTHZ_EVENT_ENABLED:true}
      redis-channel: ${USER_AUTHZ_EVENT_REDIS_CHANNEL:shiori.authz.user.changed}
  outbox:
    enabled: ${USER_OUTBOX_ENABLED:true}
    relay-fixed-delay-ms: ${USER_OUTBOX_RELAY_FIXED_DELAY_MS:3000}
    relay-batch-size: ${USER_OUTBOX_RELAY_BATCH_SIZE:100}
    max-backoff-seconds: ${USER_OUTBOX_MAX_BACKOFF_SECONDS:300}
  mq:
    enabled: ${USER_MQ_ENABLED:true}
    event-exchange: ${USER_EVENT_EXCHANGE:shiori.user.event}
    user-status-changed-routing-key: ${USER_STATUS_CHANGED_ROUTING_KEY:user.status.changed}
    user-role-changed-routing-key: ${USER_ROLE_CHANGED_ROUTING_KEY:user.role.changed}
    user-password-reset-routing-key: ${USER_PASSWORD_RESET_ROUTING_KEY:user.password.reset}
    user-permission-override-changed-routing-key: ${USER_PERMISSION_OVERRIDE_CHANGED_ROUTING_KEY:user.permission-override.changed}
    user-role-bindings-changed-routing-key: ${USER_ROLE_BINDINGS_CHANGED_ROUTING_KEY:user.role-bindings.changed}
  avatar:
    storage:
      endpoint: ${PRODUCT_OSS_ENDPOINT}
      bucket: ${MINIO_PRODUCT_BUCKET}
      path-style-access: true
      public-path-prefix: /api/user/media/avatar/
  payment-client:
    service-base-url: ${USER_PAYMENT_SERVICE_BASE_URL:http://shiori-payment-service}
