spring:
  kafka:
    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS}
    consumer:
      key-deserializer: org.apache.kafka.common.serialization.StringDeserializer
      value-deserializer: org.apache.kafka.common.serialization.StringDeserializer
      enable-auto-commit: false
      auto-offset-reset: latest
    listener:
      ack-mode: manual
      missing-topics-fatal: false

server:
  port: 8086

search:
  kafka:
    enabled: ${SEARCH_KAFKA_ENABLED}
    product-outbox-topic: ${SEARCH_PRODUCT_OUTBOX_TOPIC}
    product-outbox-group-id: ${SEARCH_PRODUCT_OUTBOX_GROUP_ID}
  elasticsearch:
    endpoint: ${SEARCH_ELASTICSEARCH_ENDPOINT}
    index-name: ${SEARCH_ELASTICSEARCH_INDEX_NAME}

management:
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  endpoint:
    health:
      show-details: never
