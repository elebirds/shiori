spring:
  datasource:
    url: ${PRODUCT_DB_URL}
  rabbitmq:
    host: ${PRODUCT_RMQ_HOST}
    port: ${PRODUCT_RMQ_PORT}
    virtual-host: /
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT}
  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration

mybatis:
  mapper-locations: classpath*:mapper/**/*.xml
  configuration:
    map-underscore-to-camel-case: true

chat:
  ticket:
    issuer: ${CHAT_TICKET_ISSUER}
    ttl-seconds: ${CHAT_TICKET_TTL_SECONDS}
    kid: ${CHAT_TICKET_KID}

storage:
  oss:
    enabled: true
    endpoint: ${PRODUCT_OSS_ENDPOINT}
    region: us-east-1
    bucket: shiori-product
    path-style-access: true
    presign-put-expire-seconds: 300
    presign-get-expire-seconds: 300

product:
  outbox:
    enabled: ${PRODUCT_OUTBOX_ENABLED:true}
    relay-fixed-delay-ms: ${PRODUCT_OUTBOX_RELAY_FIXED_DELAY_MS:3000}
    relay-batch-size: ${PRODUCT_OUTBOX_RELAY_BATCH_SIZE:100}
    max-backoff-seconds: ${PRODUCT_OUTBOX_MAX_BACKOFF_SECONDS:300}
  mq:
    enabled: ${PRODUCT_MQ_ENABLED:true}
    event-exchange: ${PRODUCT_EVENT_EXCHANGE:shiori.product.event}
    product-published-routing-key: ${PRODUCT_PUBLISHED_ROUTING_KEY:product.published}

management:
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  endpoint:
    health:
      show-details: never
