spring:
  datasource:
    url: ${PRODUCT_DB_URL}
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT}
  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration

mybatis:
  mapper-locations: classpath*:mapper/**/*.xml
  configuration:
    map-underscore-to-camel-case: true

chat:
  ticket:
    issuer: ${CHAT_TICKET_ISSUER}
    ttl-seconds: ${CHAT_TICKET_TTL_SECONDS}
    kid: ${CHAT_TICKET_KID}

storage:
  oss:
    enabled: true
    endpoint: ${PRODUCT_OSS_ENDPOINT}
    region: us-east-1
    bucket: shiori-product
    path-style-access: true
    presign-put-expire-seconds: 300
    presign-get-expire-seconds: 300

product:
  outbox:
    enabled: ${PRODUCT_OUTBOX_ENABLED:true}
  mq:
    event-exchange: ${PRODUCT_EVENT_EXCHANGE:shiori.product.event}
    product-published-routing-key: ${PRODUCT_PUBLISHED_ROUTING_KEY:product.published}
  search:
    enabled: ${PRODUCT_SEARCH_ENABLED}
    endpoint: ${PRODUCT_SEARCH_ENDPOINT}
    index-name: ${PRODUCT_SEARCH_INDEX_NAME}
    connect-timeout: ${PRODUCT_SEARCH_CONNECT_TIMEOUT}
    read-timeout: ${PRODUCT_SEARCH_READ_TIMEOUT}
    mysql-fallback-enabled: ${PRODUCT_SEARCH_MYSQL_FALLBACK_ENABLED}

management:
  defaults:
    metrics:
      export:
        enabled: false
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  endpoint:
    health:
      show-details: never
  tracing:
    enabled: ${TRACING_ENABLED:true}
    sampling:
      probability: ${TRACING_SAMPLING_PROBABILITY:1.0}
    propagation:
      consume: [w3c]
      produce: [w3c]
  opentelemetry:
    resource-attributes:
      service.namespace: shiori
      deployment.environment: ${SHIORI_ENV:dev}
    tracing:
      export:
        otlp:
          endpoint: ${OTEL_EXPORTER_OTLP_ENDPOINT:http://jaeger:4318/v1/traces}
  otlp:
    metrics:
      export:
        enabled: false
  logging:
    export:
      otlp:
        enabled: false

logging:
  include-application-name: false
  pattern:
    correlation: "[${spring.application.name:},%X{traceId:-},%X{spanId:-}] "
