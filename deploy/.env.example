# ------------------------------
# Environment Layering
# ------------------------------
SHIORI_ENV=dev
NACOS_CONFIG_GROUP=SHIORI_DEV_DOCKER
NACOS_CONFIG_GROUP_LOCAL=SHIORI_DEV_LOCAL
NACOS_CONFIG_NAMESPACE=

# ------------------------------
# Infrastructure Credentials (Sensitive)
# ------------------------------
MYSQL_ROOT_PASSWORD=__CHANGE_ME__
MYSQL_OPS_PASSWORD=__CHANGE_ME__
USER_DB_PASSWORD=__CHANGE_ME__
PRODUCT_DB_PASSWORD=__CHANGE_ME__
ORDER_DB_PASSWORD=__CHANGE_ME__
PAYMENT_DB_PASSWORD=__CHANGE_ME__
NOTIFY_DB_PASSWORD=__CHANGE_ME__
RABBITMQ_DEFAULT_PASS=__CHANGE_ME__
ORDER_RMQ_PASSWORD=__CHANGE_ME__
USER_RMQ_PASSWORD=__CHANGE_ME__
NOTIFY_RMQ_PASSWORD=__CHANGE_ME__
MINIO_ROOT_PASSWORD=__CHANGE_ME__
MINIO_PRODUCT_SECRET_KEY=__CHANGE_ME__
NACOS_AUTH_TOKEN=__CHANGE_ME__
NACOS_IMPORT_PASSWORD=__CHANGE_ME__
NACOS_PASSWORD=__CHANGE_ME__
JWT_HMAC_SECRET=__CHANGE_ME__
GATEWAY_SIGN_SECRET=__CHANGE_ME__
ORDER_PAYMENT_INTERNAL_TOKEN=__CHANGE_ME_32_PLUS_CHARS__
CHAT_TICKET_PRIVATE_KEY_PEM_BASE64=__CHANGE_ME__
NOTIFY_CHAT_TICKET_PUBLIC_KEY_PEM_BASE64=__CHANGE_ME__

# ------------------------------
# Infrastructure Non-sensitive
# ------------------------------
MYSQL_OPS_USERNAME=shiori_ops
RABBITMQ_DEFAULT_USER=rabbitmq_admin
ORDER_RMQ_USERNAME=order_service
USER_RMQ_USERNAME=user_service
NOTIFY_RMQ_USERNAME=notify_service
NOTIFY_DB_USERNAME=notify_service
PAYMENT_DB_USERNAME=payment_service
CHAT_TICKET_ISSUER=shiori-chat-ticket
CHAT_TICKET_TTL_SECONDS=300
CHAT_TICKET_KID=chat-ticket-kid
NOTIFY_HTTP_ADDR=:8090
NOTIFY_WS_PATH=/ws
NOTIFY_CHAT_ENABLED=true
NOTIFY_CHAT_DEFAULT_LIMIT=20
NOTIFY_CHAT_MAX_LIMIT=100
NOTIFY_CHAT_MQ_ENABLED=true
NOTIFY_CHAT_MQ_EXCHANGE=shiori.chat.event
NOTIFY_CHAT_USER_SERVICE_TIMEOUT_MS=800
NOTIFY_INSTANCE_ID=
MINIO_ROOT_USER=minio_admin
MINIO_PRODUCT_BUCKET=shiori-product
MINIO_PRODUCT_ACCESS_KEY=product_service
NACOS_AUTH_IDENTITY_KEY=__CHANGE_ME__
NACOS_AUTH_IDENTITY_VALUE=__CHANGE_ME__
NACOS_IMPORT_USERNAME=nacos
NACOS_USERNAME=nacos
NACOS_ADDR=127.0.0.1:8848
NACOS_CONSOLE_PORT=18080
REDIS_HOST_PORT=6379
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ------------------------------
# Nacos Template Variables (docker env)
# ------------------------------
USER_DB_URL_DOCKER=jdbc:mysql://mysql:3306/shiori_user?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
USER_DB_USERNAME=user_service

PRODUCT_DB_URL_DOCKER=jdbc:mysql://mysql:3306/shiori_product?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
PRODUCT_DB_USERNAME=product_service

ORDER_DB_URL_DOCKER=jdbc:mysql://mysql:3306/shiori_order?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
ORDER_DB_USERNAME=order_service

PAYMENT_DB_URL_DOCKER=jdbc:mysql://mysql:3306/shiori_payment?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false

REDIS_HOST_DOCKER=redis
REDIS_PORT_DOCKER=6379
ORDER_RMQ_HOST_DOCKER=rabbitmq
ORDER_RMQ_PORT_DOCKER=5672
USER_RMQ_HOST_DOCKER=rabbitmq
USER_RMQ_PORT_DOCKER=5672
NOTIFY_RMQ_HOST_DOCKER=rabbitmq
NOTIFY_RMQ_PORT_DOCKER=5672
NOTIFY_DB_HOST_DOCKER=mysql
NOTIFY_DB_PORT_DOCKER=3306
NOTIFY_DB_NAME_DOCKER=shiori_notify
PRODUCT_OSS_ENDPOINT_DOCKER=http://minio:9000
ORDER_PRODUCT_SERVICE_BASE_URL_DOCKER=http://shiori-product-service
ORDER_PAYMENT_SERVICE_BASE_URL_DOCKER=http://shiori-payment-service
NOTIFY_CHAT_USER_SERVICE_BASE_URL_DOCKER=http://shiori-user-service:8081

