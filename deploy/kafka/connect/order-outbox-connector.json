{
  "connector.class": "io.debezium.connector.mysql.MySqlConnector",
  "database.hostname": "mysql",
  "database.port": "3306",
  "database.user": "__CDC_DB_USERNAME__",
  "database.password": "__CDC_DB_PASSWORD__",
  "database.server.id": "5401",
  "database.include.list": "shiori_order",
  "table.include.list": "shiori_order.o_outbox_event",
  "topic.prefix": "shiori_cdc_order",
  "message.key.columns": "shiori_order.o_outbox_event:event_id",
  "include.schema.changes": "false",
  "snapshot.mode": "no_data",
  "tombstones.on.delete": "false",
  "schema.history.internal.kafka.bootstrap.servers": "kafka:29092",
  "schema.history.internal.kafka.topic": "schema-changes.shiori-order",
  "transforms": "unwrap,route",
  "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
  "transforms.unwrap.delete.handling.mode": "drop",
  "transforms.unwrap.drop.tombstones": "true",
  "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
  "transforms.route.regex": "(.*)",
  "transforms.route.replacement": "shiori.cdc.order.outbox.raw"
}
